.build/
.swiftpm/
DerivedData/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
Package.resolved

# macOS
.DS_Store
*.swp

# Build output & notarization artifacts
build/
dist/
*.dmg
*.app.zip

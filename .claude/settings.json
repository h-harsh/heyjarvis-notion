{
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./.claude/settings.local.json)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat .ai/STATE.md 2>/dev/null || echo 'No .ai/STATE.md — fresh start.'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path'); case \"$f\" in *.swift) command -v swiftlint >/dev/null 2>&1 && swiftlint lint --quiet --path \"$f\" 2>&1 | tail -20 >&2; exit 0 ;; esac; exit 0"
          }
        ]
      }
    ]
  }
}
